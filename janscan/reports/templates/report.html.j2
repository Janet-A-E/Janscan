<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JanScan Report — {{ scan.hostname }}</title>
<style>
  :root {
    --bg: #0d1117; --bg2: #161b22; --bg3: #21262d;
    --border: #30363d; --text: #e6edf3; --dim: #8b949e;
    --green: #00ff88; --amber: #ffb700; --red: #ff4444;
    --blue: #58a6ff; --critical: #ff2222; --high: #ff6644;
    --medium: #ffb700; --low: #44aaff; --pass: #00ff88; --info: #8b949e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, monospace; font-size: 14px; }
  .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
  header { text-align: center; padding: 40px 0 24px; border-bottom: 1px solid var(--border); margin-bottom: 32px; }
  header h1 { font-family: monospace; font-size: 2.2em; color: var(--red); letter-spacing: 2px; }
  header .meta { color: var(--dim); margin-top: 8px; font-size: 0.9em; }
  .score-panel { display: flex; align-items: center; gap: 40px; background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 32px; margin-bottom: 28px; }
  .score-circle { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
  .score-circle svg { width: 140px; height: 140px; }
  .score-info h2 { font-size: 1.8em; margin-bottom: 6px; }
  .score-info .grade-label { color: var(--dim); font-size: 1em; }
  .summary-bars { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 28px; }
  .summary-bars h2 { margin-bottom: 16px; color: var(--dim); font-size: 1em; text-transform: uppercase; letter-spacing: 1px; }
  .bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-size: 0.9em; }
  .bar-label { width: 80px; font-weight: bold; }
  .bar-track { flex: 1; background: var(--bg3); border-radius: 4px; height: 18px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s; }
  .bar-count { width: 40px; text-align: right; color: var(--dim); }
  .modules { margin-bottom: 28px; }
  .modules h2 { margin-bottom: 16px; color: var(--dim); font-size: 1em; text-transform: uppercase; letter-spacing: 1px; }
  details { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 10px; }
  summary { padding: 14px 18px; cursor: pointer; font-weight: bold; user-select: none; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  summary:hover { background: var(--bg3); border-radius: 8px; }
  summary::marker { display: none; }
  .module-content { padding: 0 18px 18px; }
  .finding-card { border: 1px solid var(--border); border-radius: 6px; padding: 12px 14px; margin-top: 10px; background: var(--bg); }
  .finding-card .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.75em; font-weight: bold; margin-bottom: 6px; color: #000; }
  .finding-card h4 { font-size: 0.95em; margin-bottom: 4px; }
  .finding-card .desc { color: var(--dim); font-size: 0.85em; margin-bottom: 4px; }
  .finding-card .rec { color: var(--blue); font-size: 0.82em; font-style: italic; }
  .finding-card .raw { background: var(--bg3); border-radius: 4px; padding: 8px; font-family: monospace; font-size: 0.78em; color: var(--dim); margin-top: 6px; white-space: pre-wrap; max-height: 120px; overflow-y: auto; }
  .top-issues { background: var(--bg2); border: 1px solid var(--critical); border-radius: 12px; padding: 24px; margin-bottom: 28px; }
  .top-issues h2 { color: var(--critical); margin-bottom: 16px; font-size: 1em; text-transform: uppercase; letter-spacing: 1px; }
  .issue-item { border-left: 3px solid; padding: 10px 14px; margin-bottom: 10px; background: var(--bg3); border-radius: 0 6px 6px 0; }
  .issue-item .sev { font-size: 0.75em; font-weight: bold; margin-bottom: 4px; }
  .issue-item h4 { font-size: 0.9em; margin-bottom: 3px; }
  .issue-item .rec { font-size: 0.82em; color: var(--blue); font-style: italic; }
  footer { text-align: center; color: var(--dim); font-size: 0.8em; padding: 32px 0; border-top: 1px solid var(--border); margin-top: 40px; }
  .tag { display: inline-block; background: var(--bg3); color: var(--dim); border-radius: 3px; padding: 1px 6px; font-size: 0.72em; margin-right: 3px; }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>JANSCAN</h1>
    <div class="meta">
      Linux Security Audit Report &nbsp;|&nbsp;
      Host: <strong>{{ scan.hostname }}</strong> &nbsp;|&nbsp;
      {{ scan.started_at | string | truncate(19, True, '') }} &nbsp;|&nbsp;
      Generated: {{ generated_at }}
    </div>
  </header>

  <!-- Score Panel -->
  <div class="score-panel">
    <div class="score-circle">
      <svg viewBox="0 0 140 140">
        <circle cx="70" cy="70" r="60" fill="#161b22" stroke="{{ grade_color }}" stroke-width="6"/>
        <text x="70" y="80" text-anchor="middle" font-size="38" font-weight="bold" fill="{{ grade_color }}" font-family="monospace">{{ score }}</text>
        <text x="70" y="100" text-anchor="middle" font-size="14" fill="{{ grade_color }}" font-family="monospace">{{ grade }}</text>
      </svg>
    </div>
    <div class="score-info">
      <h2 style="color: {{ grade_color }}">Score: {{ score }}/100</h2>
      <div class="grade-label">Grade {{ grade }} — {{ grade_label }}</div>
      <div style="margin-top: 12px; color: #8b949e; font-size: 0.85em;">
        {{ total_critical }} Critical &nbsp; {{ total_high }} High &nbsp;
        {{ total_medium }} Medium &nbsp; {{ total_low }} Low &nbsp;
        {{ total_pass }} Pass &nbsp; {{ total_info }} Info
      </div>
    </div>
  </div>

  <!-- Summary Bars -->
  {% set max_count = [total_critical, total_high, total_medium, total_low, total_pass, total_info] | max %}
  {% set max_count = max_count if max_count > 0 else 1 %}
  <div class="summary-bars">
    <h2>Findings by Severity</h2>
    {% for sev, count, color in [
      ('CRITICAL', total_critical, '#ff2222'),
      ('HIGH', total_high, '#ff6644'),
      ('MEDIUM', total_medium, '#ffb700'),
      ('LOW', total_low, '#44aaff'),
      ('PASS', total_pass, '#00ff88'),
      ('INFO', total_info, '#8b949e')
    ] %}
    <div class="bar-row">
      <span class="bar-label" style="color: {{ color }}">{{ sev }}</span>
      <div class="bar-track">
        <div class="bar-fill" style="width: {{ (count / max_count * 100) | round }}%; background: {{ color }}"></div>
      </div>
      <span class="bar-count">{{ count }}</span>
    </div>
    {% endfor %}
  </div>

  <!-- Top Issues -->
  {% if top_issues %}
  <div class="top-issues">
    <h2>⚠ Top Critical &amp; High Findings</h2>
    {% for f in top_issues %}
    <div class="issue-item" style="border-color: {{ f.color }}">
      <div class="sev" style="color: {{ f.color }}">{{ f.severity }}</div>
      <h4>{{ f.title }}</h4>
      {% if f.recommendation %}<div class="rec">→ {{ f.recommendation }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Module Findings -->
  <div class="modules">
    <h2>Findings by Module</h2>
    {% for mod in modules %}
    <details>
      <summary>
        <span>{{ mod.display_name }}</span>
        <span style="color: #8b949e; font-size: 0.85em; font-weight: normal;">{{ mod.findings | length }} finding(s)</span>
      </summary>
      <div class="module-content">
        {% if not mod.findings %}
          <p style="color: #8b949e; padding: 10px 0;">No findings for this module.</p>
        {% endif %}
        {% for f in mod.findings %}
        <div class="finding-card">
          <span class="badge" style="background: {{ f.color }}">{{ f.severity }}</span>
          <h4>{{ f.title }}</h4>
          {% if f.description %}<div class="desc">{{ f.description }}</div>{% endif %}
          {% if f.recommendation %}<div class="rec">→ {{ f.recommendation }}</div>{% endif %}
          {% if f.tags %}
            <div style="margin-top: 6px;">{% for tag in f.tags %}<span class="tag">#{{ tag }}</span>{% endfor %}</div>
          {% endif %}
          {% if f.raw_output %}<div class="raw">{{ f.raw_output }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </div>

  <footer>
    JanScan v1.0.0 &nbsp;|&nbsp; Generated {{ generated_at }} &nbsp;|&nbsp; CONFIDENTIAL
  </footer>
</div>
</body>
</html>
